# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binaries
*.test

# Coverage and test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Build output and caches anywhere in the repo
**/bin/
**/build/
**/dist/
**/out/
**/tmp/
**/.cache/
.codex

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace files
go.work
go.work.sum

# Local environment files anywhere in the repo
.env
.env.*
**/.env
**/.env.*
!.env.example
!.env.sample
!**/.env.example
!**/.env.sample

# Secrets and certificates anywhere in the repo
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.csr
*.der
*.jks
**/secret/
**/secrets/

# Editor/IDE
.idea/
.vscode/

# OS files
.DS_Store
